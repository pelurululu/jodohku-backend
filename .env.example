# === JODOHKU.MY Environment Configuration ===
# Copy this to .env and fill in actual values

# Application
APP_NAME=Jodohku.my
APP_VERSION=2.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production
ALLOWED_ORIGINS=http://localhost:3000,https://jodohku.my

# Database
DATABASE_URL=postgresql+asyncpg://jodohku_user:password@localhost:5432/jodohku_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ToyyibPay Payment Gateway
TOYYIBPAY_SECRET_KEY=your-toyyibpay-secret
TOYYIBPAY_CATEGORY_CODE=your-category-code
TOYYIBPAY_BASE_URL=https://toyyibpay.com
TOYYIBPAY_CALLBACK_URL=https://api.jodohku.my/api/v1/payment/callback

# Billplz (Failover)
BILLPLZ_API_KEY=your-billplz-key
BILLPLZ_COLLECTION_ID=your-collection-id
BILLPLZ_BASE_URL=https://www.billplz-sandbox.com/api/v3

# SenangPay (Failover)
SENANGPAY_MERCHANT_ID=your-merchant-id
SENANGPAY_SECRET_KEY=your-senangpay-secret

# e-KYC Provider (Jumio)
EKYC_API_KEY=your-ekyc-api-key
EKYC_API_SECRET=your-ekyc-api-secret
EKYC_BASE_URL=https://netverify.com/api/v4

# Liveness Detection (iProov)
IPROOV_API_KEY=your-iproov-api-key
IPROOV_SECRET=your-iproov-secret
IPROOV_BASE_URL=https://eu.rp.secure.iproov.me/api/v2

# CTOS (Background Check - Sovereign Tier)
CTOS_API_KEY=your-ctos-api-key
CTOS_BASE_URL=https://api.ctos.com.my

# Firebase Cloud Messaging
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-firebase-project-id

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@jodohku.my
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=Jodohku.my

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-id

# Cloudflare
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_API_TOKEN=your-cf-token

# Sentry Monitoring
SENTRY_DSN=your-sentry-dsn

# File Upload
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
UPLOAD_DIR=/var/jodohku/uploads

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LOGIN_PER_MINUTE=5
